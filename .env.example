# Database (local Docker Compose)
DATABASE_URL="postgresql://vibe_tape:vibe_tape@localhost:5432/vibe_tape?sslmode=disable"
DIRECT_URL="postgresql://vibe_tape:vibe_tape@localhost:5432/vibe_tape?sslmode=disable"

# Auth (Better Auth)
# BETTER_AUTH_SECRET: generate with `openssl rand -base64 32`
BETTER_AUTH_SECRET=""
# BETTER_AUTH_URL: use 127.0.0.1 (Spotify no longer supports localhost redirect URIs)
BETTER_AUTH_URL="http://127.0.0.1:3000"

# Spotify OAuth
SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""

# AI
ANTHROPIC_API_KEY=""

# Last.fm
LASTFM_API_KEY=""

# Background Jobs (Inngest)
# Local dev only — INNGEST_DEV=1 points the SDK at the Docker-based Inngest Dev Server
# and skips signing key verification.
INNGEST_DEV="1"
